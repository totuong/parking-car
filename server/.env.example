# Nguồn live: MJPEG từ camera giả lập (ưu tiên). Không set = fallback poll dataset.
CAMERA_STREAM_URL=http://127.0.0.1:8081/stream/mjpeg
# Phải khớp CAMERA_STREAM_SECRET bên camera (header X-API-Key). Để trống nếu camera tắt auth.
CAMERA_STREAM_SECRET=change-me-camera-stream

# Fallback poll dataset (chỉ khi không có CAMERA_STREAM_URL)
# FRAMES_DATASET_PATH=../../20252B-digital-twin/data_clean
FRAME_POLL_INTERVAL_SECONDS=1
FRAME_LOOP_DATASET=true
INGEST_STALE_SECONDS=5
API_PORT=8000
# Bảo mật API bằng HMAC-SHA256. Để trống = tắt auth (dev local).
IOT_DEVICE_SECRETS=web-client:change-me-web-secret
HMAC_TIMESTAMP_TOLERANCE_SECONDS=300
HMAC_NONCE_TTL_SECONDS=300
# Chỉ các origin này được gọi API từ trình duyệt (CORS).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
