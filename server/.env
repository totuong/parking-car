MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_TOPIC=parking/frames
# Broker trong 20252B-digital-twin đã bật allow_anonymous false,
# nên parking-bridge phải dùng user/password khớp password_file + acl_file.
MQTT_REQUIRE_AUTH=true
MQTT_USERNAME=parking_sub
MQTT_PASSWORD=parking_sub_secret
# Chạy Docker: dùng doker-/docker-compose.yml (mount ../20252B-digital-twin/data_clean → /data/dataset).
# Chạy uvicorn local: bỏ comment dòng dưới hoặc để mặc định (main.py tự trỏ tới 20252B-digital-twin/data_clean).
# FRAMES_DATASET_PATH=../../20252B-digital-twin/data_clean
API_PORT=8000
# Bảo mật Web (OWASP): đặt mật khẩu API. Để trống = tắt auth (dev local).
API_SECRET=change-me-api-secret
# Chỉ các origin này được gọi API từ trình duyệt (CORS).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATABASE_URL="postgresql://neondb_owner:npg_VDXTCy83ZoqK@ep-weathered-hat-adhtqcmr-pooler.c-2.us-east-1.aws.neon.tech/parking-twin?sslmode=require&channel_binding=require"
